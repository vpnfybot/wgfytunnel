{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flutter app on Pixel 9a emulator",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"emulator-5556"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Flutter app on connected Android device",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"android"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}